# ─────────────────────────────────────────────────────────────
# active_memory configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────

# Provider selection: ollama | anthropic | huggingface
ACTIVE_MEMORY_BACKEND=ollama

# Model identifier — leave blank to use each provider's default:
#   ollama      -> gemma3:4b
#   anthropic   -> claude-haiku-4-5
#   huggingface -> (required — no default)
ACTIVE_MEMORY_MODEL=

# ── Ollama ──────────────────────────────────────────────────
# Only needed when ACTIVE_MEMORY_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic ───────────────────────────────────────────────
# Only needed when ACTIVE_MEMORY_BACKEND=anthropic
ANTHROPIC_API_KEY=

# ── Hugging Face ────────────────────────────────────────────
# Only needed when ACTIVE_MEMORY_BACKEND=huggingface
HF_TOKEN=

# ── Cloud provider tuning ───────────────────────────────────
# Max tokens in the response (anthropic and huggingface only)
ACTIVE_MEMORY_MAX_TOKENS=2048
